# Metrolinx Open Data API key
# Register at: https://www.metrolinx.com/en/aboutmetrolinx/open-data.aspx
METROLINX_API_KEY=your_key_here

# Upstash Redis (optional — falls back to in-memory cache if not set)
# Create free instance at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Server
PORT=3000
CORS_ORIGIN=*

# Set automatically in Dockerfile — override only if running outside Docker
# TZ=America/Toronto
